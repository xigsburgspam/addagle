rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - photoURL: string
    //   - role: string (admin/user)
    //   - isBlocked: boolean
    //   - createdAt: timestamp
    //
    // Collection: reports
    // Document ID: {reportId}
    // Fields:
    //   - reporterId: string (required)
    //   - reportedId: string (required)
    //   - reason: string (required)
    //   - timestamp: timestamp (required)
    //   - roomId: string
    //
    // Collection: blocked_emails
    // Document ID: {email}
    // Fields:
    //   - blockedAt: timestamp
    //   - reason: string
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          request.auth.token.email == "edublitz71@gmail.com" ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isNotBlocked() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return !('isBlocked' in userDoc.data) || userDoc.data.isBlocked == false;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'] &&
             (!('isBlocked' in data) || data.isBlocked is bool);
    }

    function isValidReport(data) {
      return data.keys().hasAll(['reporterId', 'reportedId', 'reason', 'timestamp']) &&
             data.reporterId == request.auth.uid &&
             data.reportedId is string &&
             data.reason is string &&
             data.timestamp is timestamp;
    }

    function isValidFootballMatch(data) {
      return data.keys().hasAll(['teamA', 'teamB', 'league', 'streamUrl', 'live', 'createdAt']) &&
             data.teamA is string && data.teamA.size() > 0 && data.teamA.size() < 100 &&
             data.teamB is string && data.teamB.size() > 0 && data.teamB.size() < 100 &&
             data.league is string && data.league.size() > 0 && data.league.size() < 100 &&
             data.streamUrl is string && data.streamUrl.size() > 0 && data.streamUrl.size() < 1000 &&
             data.live is bool &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'user' || (request.resource.data.role == 'admin' && request.auth.token.email == "edublitz71@gmail.com"));
      allow update: if isAuthenticated() && (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.isBlocked == resource.data.isBlocked));
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isNotBlocked() && isValidReport(request.resource.data);
      allow delete: if isAdmin();
    }

    match /blocked_emails/{email} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.token.email == email);
      allow write: if isAdmin();
    }

    match /stats/global {
      allow read: if true;
      allow write: if true;
    }

    match /presence/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) && isNotBlocked();
    }

    match /football_matches/{matchId} {
      allow read: if true;
      allow create: if isAdmin() && isValidFootballMatch(request.resource.data);
      allow update: if isAdmin() && isValidFootballMatch(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        request.auth.token.email == "edublitz71@gmail.com";
    }

    function isNotBlocked() {
      return !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBlocked', false) == false;
    }

    // ── users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Owner reads their own doc; admin reads all
      allow read: if isOwner(userId) || isAdmin();

      // Any authenticated user can create their own document (no field validation
      // so the write is never blocked by a type mismatch or missing field)
      allow create: if isOwner(userId) && isAuthenticated();

      // Owner can update their own doc but cannot elevate role or change blocked status
      // Admin can update anything
      allow update: if isAdmin() ||
                    (isOwner(userId) &&
                     request.resource.data.role == resource.data.role &&
                     request.resource.data.get('isBlocked', false) == resource.data.get('isBlocked', false));

      allow delete: if isAdmin();
    }

    // ── reports ────────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isNotBlocked() &&
                    request.resource.data.keys().hasAll(['reporterId','reportedId','reason','timestamp']) &&
                    request.resource.data.reporterId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── blocked_emails ─────────────────────────────────────────────────────
    match /blocked_emails/{email} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.token.email == email);
      allow write: if isAdmin();
    }

    // ── stats ──────────────────────────────────────────────────────────────
    match /stats/global {
      allow read, write: if true;
    }

    // ── presence ───────────────────────────────────────────────────────────
    match /presence/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) && isNotBlocked();
    }

    // ── football_matches ───────────────────────────────────────────────────
    match /football_matches/{matchId} {
      allow read: if true;
      allow create, update: if isAdmin() &&
                    request.resource.data.keys().hasAll(['teamA','teamB','league','streamUrl','live','createdAt']);
      allow delete: if isAdmin();
    }

    // ── blocks ─────────────────────────────────────────────────────────────
    match /blocks/{blockId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}

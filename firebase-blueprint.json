{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and moderation status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "isBlocked": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Report": {
      "title": "Report",
      "description": "Moderation report for inappropriate content",
      "type": "object",
      "properties": {
        "reporterId": { "type": "string" },
        "reportedId": { "type": "string" },
        "reason": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "roomId": { "type": "string" }
      },
      "required": ["reporterId", "reportedId", "reason", "timestamp"]
    },
    "Stats": {
      "title": "Stats",
      "description": "Global application statistics",
      "type": "object",
      "properties": {
        "onlineUsers": { "type": "integer" },
        "videoChatting": { "type": "integer" },
        "textChatting": { "type": "integer" },
        "totalChats": { "type": "integer" },
        "totalVideoChats": { "type": "integer" }
      }
    },
    "Presence": {
      "title": "Presence",
      "description": "User presence and activity status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "video", "text"] },
        "lastSeen": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Moderation reports"
    },
    "/stats/global": {
      "schema": "Stats",
      "description": "Global statistics"
    },
    "/presence/{userId}": {
      "schema": "Presence",
      "description": "User presence tracking"
    }
  }
}
